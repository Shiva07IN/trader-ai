# ════════════════════════════════════════════════════════════════════════════════
# .env.example  —  TraderAI Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# Copy to .env for local development. NEVER commit actual .env to git.
# Production values are set as environment variables in Render / Vercel dashboards.
# ════════════════════════════════════════════════════════════════════════════════

# ─── App ──────────────────────────────────────────────────────────────────────
APP_NAME=TraderAI
APP_VERSION=1.0.0
ENVIRONMENT=development           # development | staging | production
DEBUG=true

# ─── Security ─────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-generate-a-32-char-random-hex-key
JWT_SECRET_KEY=change-me-generate-a-different-32-char-key
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── Database: Supabase PostgreSQL ────────────────────────────────────────────
# 1. Create project at https://supabase.com
# 2. Go to Settings → Database → Connection String
# 3. Use the "URI" format. Replace [YOUR-PASSWORD] with your DB password.
#
# Session mode (port 5432) — for Alembic migrations & sync ops:
DATABASE_URL_SYNC=postgresql://postgres.[project-ref]:[YOUR-PASSWORD]@aws-0-ap-southeast-1.pooler.supabase.com:5432/postgres
#
# Transaction mode (port 6543) — for async FastAPI (asyncpg):
DATABASE_URL=postgresql+asyncpg://postgres.[project-ref]:[YOUR-PASSWORD]@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres
#
# Direct connection (for migrations only — NOT for app):
# DATABASE_URL_DIRECT=postgresql://postgres:[YOUR-PASSWORD]@db.[project-ref].supabase.co:5432/postgres

# ─── Redis: Upstash ───────────────────────────────────────────────────────────
# 1. Create free Redis at https://upstash.com
# 2. Go to your database → Details → REST URL / Redis URL
# Format: rediss://:password@hostname:port
REDIS_URL=rediss://:your-upstash-redis-password@your-endpoint.upstash.io:6379/0
CELERY_BROKER_URL=rediss://:your-upstash-redis-password@your-endpoint.upstash.io:6379/1
CELERY_RESULT_BACKEND=rediss://:your-upstash-redis-password@your-endpoint.upstash.io:6379/2

# ─── AI: OpenRouter (Free Models) ─────────────────────────────────────────────
# 1. Sign up free at https://openrouter.ai
# 2. Go to https://openrouter.ai/keys and create an API key
# 3. No billing required for free-tier models
OPENROUTER_API_KEY=sk-or-v1-your-openrouter-api-key-here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=google/gemma-3-27b-it:free
# Free model alternatives:
# OPENROUTER_MODEL=qwen/qwen-2.5-72b-instruct:free
# OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free
# OPENROUTER_MODEL=mistralai/mistral-7b-instruct:free

# ─── Stock Data ───────────────────────────────────────────────────────────────
# yfinance is used by default (free, no key needed)
# Optional: add paid keys for more reliable data
ALPHA_VANTAGE_API_KEY=your-alpha-vantage-key-optional
FINNHUB_API_KEY=your-finnhub-key-optional
NEWS_API_KEY=your-newsapi-org-key-optional

# ─── Google OAuth (NextAuth) ──────────────────────────────────────────────────
# 1. Go to https://console.cloud.google.com
# 2. Create OAuth 2.0 credentials
# 3. Authorised redirect URIs: https://yourdomain.com/api/auth/callback/google
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your-google-client-secret

# ─── NextAuth (Frontend — Vercel) ─────────────────────────────────────────────
# Generate secret: openssl rand -base64 32
NEXTAUTH_SECRET=your-nextauth-secret-min-32-chars-random
NEXTAUTH_URL=http://localhost:3000
# Production: NEXTAUTH_URL=https://traderai.vercel.app

# ─── API URLs ─────────────────────────────────────────────────────────────────
# Local development
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
API_URL=http://localhost:8000/api/v1
# Production (set in Vercel dashboard):
# NEXT_PUBLIC_API_URL=https://traderai-api.onrender.com/api/v1

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
CORS_ORIGINS=["http://localhost:3000","https://traderai.vercel.app","https://www.traderai.in"]

# ─── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_AI_PER_MINUTE=5

# ─── Render Deployment (backend) ──────────────────────────────────────────────
# These are auto-set by Render — do NOT configure manually
# PORT=10000               # Set by Render automatically
# RENDER=true              # Set by Render automatically
# RENDER_SERVICE_NAME=traderai-api

# ─── Local Dev Only ───────────────────────────────────────────────────────────
# Used by infra/docker-compose.yml for local postgres/redis
POSTGRES_USER=traderai
POSTGRES_PASSWORD=traderai_secret
POSTGRES_DB=traderai_db
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
REDIS_PASSWORD=redis_secret
