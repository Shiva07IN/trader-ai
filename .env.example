# ─── App ──────────────────────────────────────────────────────────────────────
APP_NAME=TraderAI
ENVIRONMENT=development   # development | staging | production
SECRET_KEY=your-super-secret-key-min-32-chars-change-this-in-prod
DEBUG=true

# ─── Database ─────────────────────────────────────────────────────────────────
POSTGRES_USER=traderai
POSTGRES_PASSWORD=traderai_secret
POSTGRES_DB=traderai_db
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://traderai:traderai_secret@localhost:5432/traderai_db
DATABASE_URL_SYNC=postgresql://traderai:traderai_secret@localhost:5432/traderai_db

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=redis_secret
REDIS_URL=redis://:redis_secret@localhost:6379/0

# ─── ChromaDB ─────────────────────────────────────────────────────────────────
CHROMA_HOST=localhost
CHROMA_PORT=8001

# ─── JWT Auth ─────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=your-jwt-secret-key-min-32-chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- OpenRouter AI (Free Model) -------------------------------------------
# 1. Sign up free at https://openrouter.ai
# 2. Go to https://openrouter.ai/keys  and create a key
# 3. Paste it below  (no billing required for free models)
OPENROUTER_API_KEY=sk-or-v1-your-openrouter-api-key-here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=google/gemma-3-27b-it:free
# Other free options: qwen/qwen-2.5-72b-instruct:free  |  inclusion-ai/ring-2.6-1t:free
OPENAI_API_KEY=   # Leave blank when using OpenRouter

# ─── External APIs ────────────────────────────────────────────────────────────
# Optional: for better Indian market data
ALPHA_VANTAGE_API_KEY=your-alpha-vantage-key
FINNHUB_API_KEY=your-finnhub-key
NEWS_API_KEY=your-newsapi-key

# ─── Google OAuth (NextAuth) ──────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ─── NextAuth (Frontend) ──────────────────────────────────────────────────────
NEXTAUTH_SECRET=your-nextauth-secret-min-32-chars
NEXTAUTH_URL=http://localhost:3000

# ─── API URLs ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
API_URL=http://localhost:8000/api/v1

# ─── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]

# ─── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_AI_PER_MINUTE=5

# ─── Celery ───────────────────────────────────────────────────────────────────
CELERY_BROKER_URL=redis://:redis_secret@localhost:6379/1
CELERY_RESULT_BACKEND=redis://:redis_secret@localhost:6379/2
